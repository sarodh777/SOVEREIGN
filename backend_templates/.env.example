# Example Environment Variables for Spring Boot Backend

# Google OAuth2 Credentials
# Get these from Google Cloud Console -> APIs & Services -> Credentials
# The user specified ID: bionic-aspect-423012-e7 is a prefix for the full client ID.
GOOGLE_OAUTH_CLIENT_ID=bionic-aspect-423012-e7.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# Email Configuration for OTP Verification
# Use an App Password from your Google Account settings, NOT your regular password.
# The user specified app password: gcre anax ftau liaz (without spaces for strict env format)
SPRING_MAIL_USERNAME=your_sender_email@gmail.com
SPRING_MAIL_APP_PASSWORD=gcreanaxftauliaz

# Setup Instructions:
# 1. Copy this file to .env
# 2. Replace 'your_sender_email@gmail.com' and 'your_google_client_secret_here' with your real values.
# 3. Use dotenv in your Spring Boot startup to load these variables, or configure them in your IDE runner.
